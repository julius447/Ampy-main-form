            "code": "<style>/* Ampy main-form — scoped extras. Canonical: ampy-redesign/css/styles.css */\n[data-mf=\"card\"]{position:relative;overflow:hidden;}\n[data-mf=\"photo\"]{position:relative;}\n[data-mf=\"photo\"] *{color:#fff;}\n[data-mf=\"logo\"]{position:absolute;top:2.9rem;left:2.9rem;z-index:5;max-width:130px;}\n[data-mf=\"quote\"]{text-shadow:0 2px 16px rgba(0,0,0,.35);max-width:34ch;margin-inline:auto;}\n[data-mf=\"stars\"] .brxe-icon,[data-mf=\"stars\"] svg,[data-mf=\"stars\"] i{color:#ffc24b !important;filter:drop-shadow(0 1px 2px rgba(0,0,0,.4));}\n[data-mf=\"rating\"]{text-decoration:none;}\n[data-mf=\"rating\"]:hover{text-decoration:underline;}\n[data-mf=\"vol\"] strong{font-weight:600;}\n[data-mf=\"steps\"] svg,[data-mf=\"steps\"] .brxe-icon,[data-mf=\"steps\"] i{color:#fff;filter:drop-shadow(0 1px 3px rgba(0,0,0,.4));}\n/* submit → Ampy teal gradient + pill (Bricks solid colour can't hold a gradient) */\n[data-mf=\"formpane\"] .brxe-form button[type=\"submit\"],[data-mf=\"formpane\"] .bricks-button{\n  background:linear-gradient(100deg,#009e88 0%,#00b597 52%,#17c6a0 100%) !important;\n  border-radius:999px !important;box-shadow:0 1rem 2.4rem -.8rem rgba(0,169,145,.45);\n  transition:transform .2s cubic-bezier(.2,.6,.2,1),filter .2s;\n}\n[data-mf=\"formpane\"] .brxe-form button[type=\"submit\"]:hover{filter:brightness(1.06);transform:translateY(-1px);}\n/* address autocomplete dropdown injected by the engine below */\n.mf-ac-list{position:absolute;z-index:40;left:0;right:0;top:calc(100% + .6rem);background:#fff;border:1px solid rgba(15,18,60,.1);border-radius:8px;box-shadow:0 2rem 4rem -1rem rgba(15,18,60,.2);overflow:hidden;max-height:26rem;overflow-y:auto;display:none;}\n.mf-ac-list.show{display:block;}\n.mf-ac-opt{display:flex;gap:1rem;align-items:center;width:100%;text-align:left;padding:1.1rem 1.4rem;font-size:1.5rem;color:#171717;background:none;border:0;border-bottom:1px solid rgba(15,18,60,.08);cursor:pointer;font-family:inherit;}\n.mf-ac-opt:last-child{border-bottom:0;}\n.mf-ac-opt:hover,.mf-ac-opt.active{background:#f7f7f7;}\n.mf-ac-opt mark{background:none;color:#00a991;font-weight:600;}\n.mf-ac-opt small{color:#6a6a6a;}\n.mf-ac-note{padding:1.2rem 1.4rem;font-size:1.35rem;color:#6a6a6a;}\n.mf-ac-anchor{position:relative;}\n.brxe-form .mf-invalid input,.brxe-form input.mf-invalid{border-color:#e00000 !important;}\n/* ============ MOBILE: full-bleed photo + floating form card (Svea mechanism) === */\n@media (max-width:768px){\n  [data-mf=\"card\"]{border-radius:0 !important;}\n  [data-mf=\"photo\"]{position:absolute !important;inset:0;z-index:0;}\n  [data-mf=\"steps\"]{position:relative;z-index:2;}\n  [data-mf=\"formpane\"]{position:relative;z-index:2;margin:2.4rem 1.6rem;border-radius:15px !important;}\n  [data-mf=\"logo\"]{display:none;}\n}</style>\n<script>/* Ampy main-form engine — enhancement layer over the native Bricks form.\n   Canonical: ampy-redesign/js/app.js. Submit + webhook = native Bricks form. */\n(function(){\n  \"use strict\";\n  var root=document.querySelector('[data-mf=\"card\"]'); if(!root) return;\n  var form=root.querySelector('.brxe-form,form'); if(!form) return;\n  function esc(s){return String(s==null?\"\":s).replace(/[&<>\"']/g,function(c){return {\"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\",'\"':\"&quot;\",\"'\":\"&#39;\"}[c];});}\n  /* Locate inputs by the Bricks name pattern form-field-<id> we set in the JSON.\n     [GAP] verify these ids survived paste (README §selectors). */\n  function byField(id){return form.querySelector('[name=\"form-field-'+id+'\"]')||form.querySelector('#form-field-'+id);}\n  var addr=byField(\"adrssf\");\n  /* ---- forgiving validation on the visible required inputs ---- */\n  function markInvalid(el,bad){ if(!el) return; el.classList.toggle(\"mf-invalid\",!!bad); el.setAttribute(\"aria-invalid\",bad?\"true\":\"false\"); }\n  var email=byField(\"emailf\"), tel=byField(\"telefn\"), fn=byField(\"fornmn\"), ln=byField(\"efternm\");\n  function vName(el){return el&&el.value.trim().length>=2;}\n  function vEmail(){return email&&/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email.value.trim());}\n  function vPhone(){return tel&&/^\\+?\\d{7,15}$/.test(tel.value.trim().replace(/[\\s\\-()]/g,\"\"));}\n  [[fn,function(){return vName(fn);}],[ln,function(){return vName(ln);}],[email,vEmail],[tel,vPhone]].forEach(function(p){\n    if(!p[0])return;\n    p[0].addEventListener(\"blur\",function(){ if(p[0].value.trim()===\"\"){markInvalid(p[0],false&&false);p[0].classList.remove(\"mf-invalid\");return;} markInvalid(p[0],!p[1]()); });\n    p[0].addEventListener(\"input\",function(){ if(p[0].classList.contains(\"mf-invalid\")&&p[1]()) markInvalid(p[0],false); });\n  });\n  /* ---- address autocomplete (Photon — free, whole of Sweden, no key) ---- */\n  if(addr){\n    var wrap=document.createElement(\"div\"); wrap.className=\"mf-ac-anchor\";\n    addr.parentNode.insertBefore(wrap,addr); wrap.appendChild(addr);\n    var list=document.createElement(\"div\"); list.className=\"mf-ac-list\"; list.setAttribute(\"role\",\"listbox\"); wrap.appendChild(list);\n    addr.setAttribute(\"role\",\"combobox\"); addr.setAttribute(\"aria-autocomplete\",\"list\"); addr.setAttribute(\"aria-expanded\",\"false\"); addr.setAttribute(\"autocomplete\",\"off\");\n    var PHOTON=\"https://photon.komoot.io/api/\", seq=0, ctrl=null, deb, cur=[], act=-1;\n    function hl(t,q){var i=t.toLowerCase().indexOf(q.toLowerCase());return (i<0||q.length<2)?esc(t):esc(t.slice(0,i))+\"<mark>\"+esc(t.slice(i,i+q.length))+\"</mark>\"+esc(t.slice(i+q.length));}\n    function close(){list.classList.remove(\"show\");addr.setAttribute(\"aria-expanded\",\"false\");act=-1;}\n    function fetchA(q,cb){q=q.trim(); if(q.length<3){cb([],\"idle\");return;} var my=++seq; if(ctrl)ctrl.abort(); ctrl=(\"AbortController\"in window)?new AbortController():null;\n      fetch(PHOTON+\"?q=\"+encodeURIComponent(q)+\"&limit=8&lat=59.33&lon=18.06\",ctrl?{signal:ctrl.signal}:undefined)\n      .then(function(r){return r.json();}).then(function(d){ if(my!==seq)return; var seen={};\n        var items=(d.features||[]).map(function(f){var p=f.properties||{};var st=p.street?(p.street+(p.housenumber?\" \"+p.housenumber:\"\")):(p.name||\"\");return{s:st,z:p.postcode||\"\",c:p.city||p.town||p.village||p.municipality||\"\",cc:p.countrycode};})\n        .filter(function(a){if(!a.s||a.cc!==\"SE\")return false;var k=a.s+a.z+a.c;if(seen[k])return false;seen[k]=1;return true;});\n        cb(items,items.length?\"ok\":\"empty\");\n      }).catch(function(e){ if(my!==seq)return; cb([],(e&&e.name===\"AbortError\")?\"abort\":\"error\"); });\n    }\n    function render(items,state,q){cur=items;act=-1;\n      if(!items.length){ if(state===\"error\"||state===\"abort\"){list.innerHTML='<div class=\"mf-ac-note\">Adressökningen svarar inte just nu &ndash; skriv adressen manuellt.</div>';list.classList.add(\"show\");addr.setAttribute(\"aria-expanded\",\"true\");}\n        else if(state===\"empty\"){list.innerHTML='<div class=\"mf-ac-note\">Inga träffar &ndash; kontrollera stavningen.</div>';list.classList.add(\"show\");addr.setAttribute(\"aria-expanded\",\"true\");} else close(); return; }\n      list.innerHTML=items.map(function(a,n){return '<button type=\"button\" class=\"mf-ac-opt\" role=\"option\" data-i=\"'+n+'\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#00a991\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg><span>'+hl(a.s,q)+' <small>'+esc(a.z)+' '+esc(a.c)+'</small></span></button>';}).join(\"\");\n      list.classList.add(\"show\"); addr.setAttribute(\"aria-expanded\",\"true\");\n    }\n    function setActive(n){act=n;var o=list.querySelectorAll(\".mf-ac-opt\");o.forEach(function(el,k){el.classList.toggle(\"active\",k===n);el.setAttribute(\"aria-selected\",k===n?\"true\":\"false\");});}\n    function pick(a){addr.value=a.s+\", \"+a.z+\" \"+a.c;markInvalid(addr,false);close();}\n    addr.addEventListener(\"input\",function(){clearTimeout(deb);var q=addr.value;deb=setTimeout(function(){fetchA(q,function(it,st){render(it,st,q);});},250);});\n    addr.addEventListener(\"blur\",function(){setTimeout(close,150);});\n    addr.addEventListener(\"keydown\",function(e){ if(!list.classList.contains(\"show\"))return; var o=list.querySelectorAll(\".mf-ac-opt\");\n      if(e.key===\"ArrowDown\"){e.preventDefault();if(o.length)setActive(Math.min(act+1,o.length-1));}\n      else if(e.key===\"ArrowUp\"){e.preventDefault();if(o.length)setActive(Math.max(act-1,0));}\n      else if(e.key===\"Enter\"){if(act>-1&&cur[act]){e.preventDefault();pick(cur[act]);}}\n      else if(e.key===\"Escape\"){close();} });\n    list.addEventListener(\"mousedown\",function(e){var b=e.target.closest(\".mf-ac-opt\");if(b){e.preventDefault();pick(cur[+b.dataset.i]);}});\n  }\n})();</script>"
